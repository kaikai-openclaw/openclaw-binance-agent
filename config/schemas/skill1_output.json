{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill1Output",
  "description": "Skill-1 量化数据采集输出（v2 — 含双向信号、ATR、ADX）",
  "type": "object",
  "properties": {
    "state_id": {
      "type": "string",
      "format": "uuid"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z0-9]{1,20}USDT$"
          },
          "quote_volume_24h": {
            "type": "number",
            "minimum": 0
          },
          "price_change_pct": {
            "type": "number"
          },
          "amplitude_pct": {
            "type": "number",
            "minimum": 0
          },
          "volume_surge_ratio": {
            "type": "number",
            "minimum": 0
          },
          "rsi": {
            "type": [
              "number",
              "null"
            ]
          },
          "ema_bullish": {
            "type": "boolean"
          },
          "macd_bullish": {
            "type": "boolean"
          },
          "signal_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "signal_direction": {
            "type": "string",
            "enum": ["long", "short"],
            "description": "信号方向：做多或做空"
          },
          "atr": {
            "type": ["number", "null"],
            "description": "ATR 绝对值，用于下游止损止盈计算"
          },
          "atr_pct": {
            "type": ["number", "null"],
            "description": "ATR 占收盘价百分比"
          },
          "adx": {
            "type": ["number", "null"],
            "description": "ADX 趋势强度指标，>25 表示有趋势"
          },
          "collected_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "symbol",
          "quote_volume_24h",
          "price_change_pct",
          "amplitude_pct",
          "volume_surge_ratio",
          "rsi",
          "ema_bullish",
          "macd_bullish",
          "signal_score",
          "signal_direction",
          "atr",
          "atr_pct",
          "adx",
          "collected_at"
        ],
        "additionalProperties": false
      }
    },
    "pipeline_run_id": {
      "type": "string",
      "format": "uuid"
    },
    "filter_summary": {
      "type": "object",
      "properties": {
        "total_tickers": {
          "type": "integer",
          "minimum": 0
        },
        "after_base_filter": {
          "type": "integer",
          "minimum": 0
        },
        "after_signal_filter": {
          "type": "integer",
          "minimum": 0
        },
        "output_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "total_tickers",
        "after_base_filter",
        "after_signal_filter",
        "output_count"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "state_id",
    "candidates",
    "pipeline_run_id",
    "filter_summary"
  ],
  "additionalProperties": false
}
