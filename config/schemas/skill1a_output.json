{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill1AOutput",
  "description": "Skill-1A A股量化数据采集输出",
  "type": "object",
  "properties": {
    "state_id": {
      "type": "string",
      "format": "uuid"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string", "pattern": "^[0-9]{6}$" },
          "name": { "type": "string" },
          "amount": { "type": "number", "minimum": 0 },
          "price_change_pct": { "type": "number" },
          "amplitude_pct": { "type": ["number", "null"], "minimum": 0 },
          "volume_surge_ratio": { "type": "number", "minimum": 0 },
          "rsi": { "type": ["number", "null"] },
          "ema_bullish": { "type": "boolean" },
          "macd_bullish": { "type": "boolean" },
          "signal_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "signal_direction": { "type": "string", "enum": ["long", "short"] },
          "atr": { "type": ["number", "null"] },
          "atr_pct": { "type": ["number", "null"] },
          "adx": { "type": ["number", "null"] },
          "collected_at": { "type": "string", "format": "date-time" }
        },
        "required": [
          "symbol", "name", "amount", "price_change_pct",
          "volume_surge_ratio", "rsi", "ema_bullish", "macd_bullish",
          "signal_score", "signal_direction", "atr", "atr_pct",
          "adx", "collected_at"
        ],
        "additionalProperties": false
      }
    },
    "pipeline_run_id": { "type": "string", "format": "uuid" },
    "filter_summary": {
      "type": "object",
      "properties": {
        "total_tickers": { "type": "integer", "minimum": 0 },
        "after_base_filter": { "type": "integer", "minimum": 0 },
        "after_signal_filter": { "type": "integer", "minimum": 0 },
        "output_count": { "type": "integer", "minimum": 0 }
      },
      "required": ["total_tickers", "after_base_filter", "after_signal_filter", "output_count"],
      "additionalProperties": false
    }
  },
  "required": ["state_id", "candidates", "pipeline_run_id", "filter_summary"],
  "additionalProperties": false
}
