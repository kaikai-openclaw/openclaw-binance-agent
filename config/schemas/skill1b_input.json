{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill1BInput",
  "description": "Skill-1B 超跌反弹筛选触发输入",
  "type": "object",
  "properties": {
    "trigger_time": {
      "type": "string",
      "format": "date-time",
      "description": "触发时间（ISO 8601）"
    },
    "target_symbols": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "指定分析的 A 股代码列表"
    },
    "min_amount": {
      "type": "number",
      "minimum": 0,
      "default": 50000000,
      "description": "最低日均成交额（元），默认 5000 万"
    },
    "min_price": {
      "type": "number",
      "minimum": 0,
      "default": 3.0,
      "description": "最低股价（元）"
    },
    "min_klines": {
      "type": "integer",
      "minimum": 30,
      "maximum": 300,
      "default": 60,
      "description": "最低 K 线数量（默认 60，约 3 个月）"
    },
    "rsi_threshold": {
      "type": "number",
      "minimum": 5,
      "maximum": 50,
      "default": 35,
      "description": "RSI(14) 超跌阈值（默认 35）"
    },
    "bias_threshold": {
      "type": "number",
      "minimum": -30,
      "maximum": -2,
      "default": -6,
      "description": "20 日乖离率阈值（%，默认 -6%）"
    },
    "consecutive_down_days": {
      "type": "integer",
      "minimum": 2,
      "maximum": 15,
      "default": 3,
      "description": "连续下跌天数阈值"
    },
    "drop_pct_threshold": {
      "type": "number",
      "minimum": -50,
      "maximum": -2,
      "default": -8,
      "description": "近 N 日累计跌幅阈值（%，默认 -8%）"
    },
    "drop_lookback_days": {
      "type": "integer",
      "minimum": 3,
      "maximum": 30,
      "default": 10,
      "description": "累计跌幅回看天数"
    },
    "min_oversold_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 25,
      "description": "超跌综合评分最低阈值（默认 25）"
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 30,
      "description": "最终输出候选数量上限（默认 30）"
    },
    "require_volume_confirm": {
      "type": "boolean",
      "default": false,
      "description": "是否要求底部放量确认"
    },
    "prefilter_change_pct": {
      "type": "number",
      "minimum": -20,
      "maximum": 0,
      "default": 0,
      "description": "当日跌幅预筛阈值（%），设 0 禁用（默认禁用，让 K 线指标判断超跌）"
    }
  },
  "required": [
    "trigger_time"
  ],
  "additionalProperties": false
}