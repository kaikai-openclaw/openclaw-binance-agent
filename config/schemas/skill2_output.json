{
  "title": "Skill2Output",
  "type": "object",
  "properties": {
    "state_id": {
      "type": "string",
      "format": "uuid"
    },
    "ratings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z]{2,10}USDT$"
          },
          "rating_score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "signal": {
            "type": "string",
            "enum": [
              "long",
              "short",
              "hold"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "symbol",
          "rating_score",
          "signal",
          "confidence"
        ],
        "additionalProperties": false
      }
    },
    "filtered_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "state_id",
    "ratings",
    "filtered_count"
  ],
  "additionalProperties": false
}