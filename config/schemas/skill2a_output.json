{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill2AOutput",
  "description": "Skill-2A A股深度分析输出",
  "type": "object",
  "properties": {
    "state_id": {
      "type": "string",
      "format": "uuid"
    },
    "ratings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string", "pattern": "^[0-9]{6}$" },
          "rating_score": { "type": "integer", "minimum": 1, "maximum": 10 },
          "signal": { "type": "string", "enum": ["long", "short", "hold"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
          "comment": { "type": "string", "description": "TradingAgents 分析摘要" }
        },
        "required": ["symbol", "rating_score", "signal", "confidence"],
        "additionalProperties": false
      }
    },
    "filtered_count": { "type": "integer", "minimum": 0 },
    "failed_symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "reason": { "type": "string" }
        },
        "required": ["symbol", "reason"]
      }
    },
    "analysis_summary": { "type": "string" }
  },
  "required": ["state_id", "ratings", "filtered_count"],
  "additionalProperties": false
}
