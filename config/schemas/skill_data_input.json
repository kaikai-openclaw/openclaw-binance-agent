{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillDataProviderInput",
  "description": "A股历史数据服务请求输入",
  "type": "object",
  "properties": {
    "symbol": {
      "type": "string",
      "pattern": "^(sh|sz|bj)\\.[0-9]{6}$",
      "description": "股票代码，必须包含交易所前缀，如 sh.600519, sz.000001, bj.830799"
    },
    "start_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "开始日期 YYYY-MM-DD"
    },
    "end_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "结束日期 YYYY-MM-DD"
    },
    "frequency": {
      "type": "string",
      "enum": ["daily"],
      "default": "daily",
      "description": "K线频率，当前仅支持日线"
    },
    "adjust": {
      "type": "string",
      "enum": ["qfq", "hfq", "none"],
      "default": "qfq",
      "description": "复权方式：qfq=前复权（默认）, hfq=后复权, none=不复权"
    }
  },
  "required": ["symbol", "start_date", "end_date"],
  "additionalProperties": false
}
