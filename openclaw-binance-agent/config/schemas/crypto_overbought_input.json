{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryptoOverboughtInput",
  "description": "加密货币合约超买做空筛选输入",
  "type": "object",
  "properties": {
    "trigger_time": {
      "type": "string",
      "format": "date-time",
      "description": "触发时间（ISO 8601）"
    },
    "target_symbols": {
      "type": "array",
      "items": { "type": "string" },
      "description": "指定分析的交易对列表（如 BTCUSDT）"
    },
    "min_quote_volume": {
      "type": "number",
      "minimum": 0,
      "default": 10000000,
      "description": "最低 24h 成交额（USDT），默认 1000 万"
    },
    "rsi_threshold": {
      "type": "number",
      "minimum": 60,
      "maximum": 95,
      "default": 80,
      "description": "RSI(14) 超买阈值（默认 80）"
    },
    "bias_threshold": {
      "type": "number",
      "minimum": 5,
      "maximum": 50,
      "default": 12,
      "description": "20 周期乖离率阈值（%，默认 +12%）"
    },
    "min_overbought_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 25,
      "description": "超买综合评分最低阈值"
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20,
      "description": "最终输出候选数量上限"
    }
  },
  "required": ["trigger_time"],
  "additionalProperties": false
}
