{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryptoOversoldInput",
  "description": "加密货币合约超跌反弹筛选输入",
  "type": "object",
  "properties": {
    "trigger_time": {
      "type": "string",
      "format": "date-time",
      "description": "触发时间（ISO 8601）"
    },
    "target_symbols": {
      "type": "array",
      "items": { "type": "string" },
      "description": "指定分析的交易对列表（如 BTCUSDT）"
    },
    "min_quote_volume": {
      "type": "number",
      "minimum": 0,
      "default": 10000000,
      "description": "最低 24h 成交额（USDT），默认 1000 万"
    },
    "kline_interval": {
      "type": "string",
      "default": "4h",
      "description": "K 线周期（默认 4h）"
    },
    "rsi_threshold": {
      "type": "number",
      "minimum": 5,
      "maximum": 40,
      "default": 25,
      "description": "RSI(14) 超跌阈值（默认 25，币圈波动大需更极端）"
    },
    "bias_threshold": {
      "type": "number",
      "minimum": -50,
      "maximum": -3,
      "default": -12,
      "description": "20 周期乖离率阈值（%，默认 -12%，币圈波动大）"
    },
    "drop_pct_threshold": {
      "type": "number",
      "minimum": -80,
      "maximum": -5,
      "default": -20,
      "description": "近 N 周期累计跌幅阈值（%，默认 -20%）"
    },
    "drop_lookback": {
      "type": "integer",
      "minimum": 6,
      "maximum": 120,
      "default": 30,
      "description": "累计跌幅回看周期数（默认 30 根 4h = 5 天）"
    },
    "consecutive_down": {
      "type": "integer",
      "minimum": 2,
      "maximum": 30,
      "default": 5,
      "description": "连续下跌 K 线数阈值（默认 5 根 4h）"
    },
    "min_oversold_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 25,
      "description": "超跌综合评分最低阈值"
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20,
      "description": "最终输出候选数量上限"
    }
  },
  "required": ["trigger_time"],
  "additionalProperties": false
}
