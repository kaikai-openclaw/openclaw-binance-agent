{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryptoOversoldOutput",
  "description": "加密货币合约超跌反弹筛选输出",
  "type": "object",
  "properties": {
    "state_id": { "type": "string", "format": "uuid" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "close": { "type": "number" },
          "current_price": { "type": "number" },
          "quote_volume_24h": { "type": "number", "minimum": 0 },
          "price_change_pct": { "type": "number" },
          "price_change_since_close_pct": { "type": "number" },
          "momentum_penalty": { "type": "number" },
          "rsi_1h": { "type": ["number", "null"] },
          "rsi_1h_trend": { "type": ["number", "null"] },
          "rsi_1h_bonus": { "type": "number" },
          "hour_candles_in_4h": { "type": "integer", "minimum": 0 },
          "elapsed_ratio": { "type": "number" },
          "closing_period_bonus": { "type": "number" },
          "support_distance_pct": { "type": ["number", "null"] },
          "is_near_support": { "type": "boolean" },
          "panic_selling_detected": { "type": "boolean" },
          "panic_penalty": { "type": "number" },
          "oversold_confirmation": {
            "type": "object",
            "properties": {
              "passed": { "type": "boolean" },
              "strong": { "type": "boolean" },
              "signal_count": { "type": "integer", "minimum": 0 },
              "momentum_count": { "type": "integer", "minimum": 0 },
              "reasons": {
                "type": "array",
                "items": { "type": "string" }
              },
              "reason": { "type": "string" }
            },
            "required": ["passed", "strong", "signal_count", "momentum_count", "reasons", "reason"],
            "additionalProperties": false
          },
          "volatility_action": { "type": "string" },
          "rsi": { "type": ["number", "null"] },
          "bias_20": { "type": ["number", "null"] },
          "consecutive_down": { "type": "integer", "minimum": 0 },
          "drop_pct": { "type": ["number", "null"] },
          "below_boll_lower": { "type": "boolean" },
          "kdj_j": { "type": ["number", "null"] },
          "macd_divergence": { "type": "boolean" },
          "volume_surge": { "type": ["number", "null"] },
          "funding_rate": { "type": ["number", "null"] },
          "oi_change_pct": { "type": ["number", "null"] },
          "distance_from_high_pct": { "type": ["number", "null"] },
          "oversold_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "signal_details": { "type": "string" },
          "atr_pct": { "type": ["number", "null"] },
          "atr_filter_pct": { "type": ["number", "null"] },
          "signal_direction": { "type": "string" },
          "strategy_tag": { "type": "string" },
          "collected_at": { "type": "string", "format": "date-time" },
          "delivery_week": { "type": "boolean" }
        },
        "required": [
          "symbol",
          "close",
          "current_price",
          "quote_volume_24h",
          "price_change_pct",
          "price_change_since_close_pct",
          "momentum_penalty",
          "rsi_1h",
          "rsi_1h_trend",
          "rsi_1h_bonus",
          "hour_candles_in_4h",
          "elapsed_ratio",
          "support_distance_pct",
          "is_near_support",
          "panic_selling_detected",
          "panic_penalty",
          "oversold_confirmation",
          "volatility_action",
          "rsi",
          "bias_20",
          "consecutive_down",
          "drop_pct",
          "below_boll_lower",
          "kdj_j",
          "macd_divergence",
          "volume_surge",
          "funding_rate",
          "oi_change_pct",
          "distance_from_high_pct",
          "oversold_score",
          "signal_details",
          "atr_pct",
          "atr_filter_pct",
          "signal_direction",
          "strategy_tag",
          "collected_at",
          "delivery_week"
        ],
        "additionalProperties": false
      }
    },
    "pipeline_run_id": { "type": "string", "format": "uuid" },
    "market_regime": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "symbol": { "type": "string" },
        "recent_return_pct": { "type": "number" }
      },
      "required": ["status", "reason"],
      "additionalProperties": false
    },
    "filter_summary": {
      "type": "object",
      "properties": {
        "total_tickers": { "type": "integer", "minimum": 0 },
        "after_base_filter": { "type": "integer", "minimum": 0 },
        "after_oversold_filter": { "type": "integer", "minimum": 0 },
        "output_count": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "total_tickers",
        "after_base_filter",
        "after_oversold_filter",
        "output_count"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "state_id",
    "candidates",
    "pipeline_run_id",
    "market_regime",
    "filter_summary"
  ],
  "additionalProperties": false
}
