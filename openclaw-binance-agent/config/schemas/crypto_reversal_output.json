{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryptoReversalOutput",
  "description": "加密货币合约底部放量反转筛选输出",
  "type": "object",
  "properties": {
    "state_id": { "type": "string", "format": "uuid" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "close": { "type": "number" },
          "current_price": { "type": "number" },
          "quote_volume_24h": { "type": "number", "minimum": 0 },
          "price_change_pct": { "type": "number" },
          "reversal_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "price_change_since_close_pct": { "type": "number" },
          "current_rsi": { "type": ["number", "null"] },
          "volume_so_far_ratio": { "type": "number" },
          "rsi_1h": { "type": ["number", "null"] },
          "vol_intraday_strength": { "type": "number" },
          "hour_candles_in_4h": { "type": "integer", "minimum": 0 },
          "elapsed_ratio_precise": { "type": "number" },
          "rsi_1h_bonus": { "type": ["integer", "null"] },
          "momentum_penalty": { "type": ["number", "null"] },
          "volume_surge_score": { "type": "integer", "minimum": 0 },
          "volume_surge_ratio": { "type": "number", "minimum": 0 },
          "price_stable_score": { "type": "integer", "minimum": 0 },
          "ma_turn_score": { "type": "integer", "minimum": 0 },
          "ma_turn_detail": { "type": "string" },
          "funding_reversal_score": { "type": "integer", "minimum": 0 },
          "funding_rate": { "type": ["number", "null"] },
          "macd_reversal_score": { "type": "integer", "minimum": 0 },
          "macd_detail": { "type": "string" },
          "dist_bottom_pct": { "type": ["number", "null"] },
          "dist_bottom_score": { "type": "integer", "minimum": 0 },
          "prior_drop_pct": { "type": ["number", "null"] },
          "prior_drop_score": { "type": "integer", "minimum": 0 },
          "kdj_score": { "type": "integer", "minimum": 0 },
          "shadow_score": { "type": "integer", "minimum": 0 },
          "reversal_confirmation": {
            "type": ["object", "null"],
            "properties": {
              "passed": { "type": "boolean" },
              "cond_dist": { "type": "boolean" },
              "cond_kdj": { "type": "boolean" },
              "cond_rsi_1h": { "type": "boolean" },
              "breakout": { "type": "boolean" },
              "pullback_hold": { "type": "boolean" },
              "reason": { "type": "string" }
            },
            "required": [
              "passed",
              "cond_dist",
              "cond_kdj",
              "cond_rsi_1h",
              "breakout",
              "pullback_hold",
              "reason"
            ],
            "additionalProperties": false
          },
          "signal_details": { "type": "string" },
          "atr_pct": { "type": ["number", "null"] },
          "atr_filter_pct": { "type": ["number", "null"] },
          "signal_direction": { "type": "string" },
          "strategy_tag": { "type": "string" },
          "collected_at": { "type": "string", "format": "date-time" },
          "delivery_week": { "type": "boolean" }
        },
        "required": [
          "symbol",
          "close",
          "current_price",
          "quote_volume_24h",
          "price_change_pct",
          "reversal_score",
          "price_change_since_close_pct",
          "current_rsi",
          "volume_so_far_ratio",
          "rsi_1h",
          "vol_intraday_strength",
          "hour_candles_in_4h",
          "elapsed_ratio_precise",
          "volume_surge_score",
          "volume_surge_ratio",
          "price_stable_score",
          "ma_turn_score",
          "ma_turn_detail",
          "funding_reversal_score",
          "funding_rate",
          "macd_reversal_score",
          "macd_detail",
          "dist_bottom_pct",
          "dist_bottom_score",
          "prior_drop_pct",
          "prior_drop_score",
          "kdj_score",
          "shadow_score",
          "reversal_confirmation",
          "signal_details",
          "atr_pct",
          "atr_filter_pct",
          "signal_direction",
          "strategy_tag",
          "collected_at",
          "delivery_week"
        ],
        "additionalProperties": false
      }
    },
    "pipeline_run_id": { "type": "string", "format": "uuid" },
    "market_regime": {
      "type": "object",
      "additionalProperties": true
    },
    "filter_summary": {
      "type": "object",
      "properties": {
        "total_tickers": { "type": "integer", "minimum": 0 },
        "after_base_filter": { "type": "integer", "minimum": 0 },
        "after_reversal_filter": { "type": "integer", "minimum": 0 },
        "output_count": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "total_tickers",
        "after_base_filter",
        "after_reversal_filter",
        "output_count"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "state_id",
    "candidates",
    "pipeline_run_id",
    "filter_summary"
  ],
  "additionalProperties": false
}
